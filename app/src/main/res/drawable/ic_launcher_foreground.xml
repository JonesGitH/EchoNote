    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Subtle accent glow behind mic -->
    <path
        android:pathData="M54,38 A16,16 0 1,1 54,70 A16,16 0 1,1 54,38 Z"
        android:fillColor="#1A6C8FFF"/>

    <!-- Microphone body (rounded rect / pill) -->
    <path android:pathData="M47,32 A7,7 0 0,1 61,32 L61,52 A7,7 0 0,1 47,52 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="25"
                android:endX="54"
                android:endY="59">
                <item android:color="#FFFFFFFF" android:offset="0"/>
                <item android:color="#FFD6DFFF" android:offset="1"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Mic grille lines -->
    <path
        android:pathData="M50,36 L58,36"
        android:fillColor="#00000000"
        android:strokeColor="#6C8FFF"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.4"/>
    <path
        android:pathData="M50,39 L58,39"
        android:fillColor="#00000000"
        android:strokeColor="#6C8FFF"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.4"/>
    <path
        android:pathData="M50,42 L58,42"
        android:fillColor="#00000000"
        android:strokeColor="#6C8FFF"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.4"/>

    <!-- Mic stand: U-shape + stem + base -->
    <path
        android:pathData="M42,52 Q42,66 54,66 Q66,66 66,52"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M54,66 L54,73"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M46,73 L62,73"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"/>

    <!-- Sound wave arcs — left inner -->
    <path
        android:pathData="M36,36 Q29,46 36,56"
        android:fillColor="#00000000"
        android:strokeColor="#6C8FFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeAlpha="0.7"/>

    <!-- Sound wave arcs — left outer -->
    <path
        android:pathData="M30,30 Q20,46 30,62"
        android:fillColor="#00000000"
        android:strokeColor="#6C8FFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeAlpha="0.4"/>

    <!-- Sound wave arcs — right inner -->
    <path
        android:pathData="M72,36 Q79,46 72,56"
        android:fillColor="#00000000"
        android:strokeColor="#6C8FFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeAlpha="0.7"/>

    <!-- Sound wave arcs — right outer -->
    <path
        android:pathData="M78,30 Q88,46 78,62"
        android:fillColor="#00000000"
        android:strokeColor="#6C8FFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeAlpha="0.4"/>

    <!-- Accent dot (the "." in Echo.Notes) -->
    <path
        android:pathData="M54,80 A2,2 0 1,1 54,84 A2,2 0 1,1 54,80 Z"
        android:fillColor="#6C8FFF"/>

</vector>
