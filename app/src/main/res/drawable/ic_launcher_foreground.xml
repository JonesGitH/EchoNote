<?xml version="1.0" encoding="utf-8"?>
<!--
  Foreground layer for EchoNote adaptive icon.
  Viewport: 352×352 (maps the icon region from the source design).
  The adaptive icon canvas is 108dp; the safe zone is the inner 72dp (18dp margin each side).
  Safe zone in viewport units: ~58–294 on both axes. Key elements (mic body, stand) sit
  within ~x:155–218, y:80–248 — well inside the safe zone.
  Outer wave arcs (~x:56,296) and the bottom transcript lines (~y:272–305) intentionally
  extend toward the bleed area for a full-bleed feel on square/rounded-square shapes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="352"
    android:viewportHeight="352">

    <!-- Sound wave arcs — left outer -->
    <path
        android:pathData="M104,98 Q56,176 104,254"
        android:fillColor="#00000000"
        android:strokeColor="#5EEAD4"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeAlpha="0.45"/>

    <!-- Sound wave arcs — left inner -->
    <path
        android:pathData="M121,115 Q84,176 121,237"
        android:fillColor="#00000000"
        android:strokeColor="#5EEAD4"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeAlpha="0.65"/>

    <!-- Sound wave arcs — right outer -->
    <path
        android:pathData="M248,98 Q296,176 248,254"
        android:fillColor="#00000000"
        android:strokeColor="#5EEAD4"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeAlpha="0.45"/>

    <!-- Sound wave arcs — right inner -->
    <path
        android:pathData="M231,115 Q268,176 231,237"
        android:fillColor="#00000000"
        android:strokeColor="#5EEAD4"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeAlpha="0.65"/>

    <!-- Microphone body (pill: w=42, h=72, rx=21, centered at x=176) -->
    <!-- Path traces: left-mid → top semicircle → right-mid → straight down → bottom semicircle → close -->
    <path android:pathData="M155,101 A21,21 0 0,0 197,101 L197,131 A21,21 0 0,0 155,131 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="176"
                android:startY="80"
                android:endX="176"
                android:endY="152">
                <item android:color="#FFFFFFFF" android:offset="0"/>
                <item android:color="#FFD0F0EC" android:offset="1"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Microphone inner detail line (subtle teal stroke inside body) -->
    <path
        android:pathData="M165,101 A11,11 0 0,0 187,101 L187,131 A11,11 0 0,0 165,131 Z"
        android:fillColor="#00000000"
        android:strokeColor="#1A7A6E"
        android:strokeWidth="1.5"
        android:strokeAlpha="0.25"/>

    <!-- Microphone stand: U-arc + vertical stem + horizontal base -->
    <path
        android:pathData="M134,176 Q134,215 176,215 Q218,215 218,176 M176,215 L176,238 M154,238 L198,238"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"/>

    <!-- Transcription lines — row 1 -->
    <path
        android:pathData="M53.5,272 L128.5,272 A2.5,2.5 0 0,1 128.5,277 L53.5,277 A2.5,2.5 0 0,1 53.5,272 Z"
        android:fillColor="#5EEAD4"
        android:fillAlpha="0.9"/>
    <path
        android:pathData="M141.5,272 L256.5,272 A2.5,2.5 0 0,1 256.5,277 L141.5,277 A2.5,2.5 0 0,1 141.5,272 Z"
        android:fillColor="#5EEAD4"
        android:fillAlpha="0.55"/>
    <path
        android:pathData="M269.5,272 L319.5,272 A2.5,2.5 0 0,1 319.5,277 L269.5,277 A2.5,2.5 0 0,1 269.5,272 Z"
        android:fillColor="#5EEAD4"
        android:fillAlpha="0.35"/>

    <!-- Transcription lines — row 2 -->
    <path
        android:pathData="M53.5,286 L178.5,286 A2.5,2.5 0 0,1 178.5,291 L53.5,291 A2.5,2.5 0 0,1 53.5,286 Z"
        android:fillColor="#5EEAD4"
        android:fillAlpha="0.6"/>
    <path
        android:pathData="M191.5,286 L276.5,286 A2.5,2.5 0 0,1 276.5,291 L191.5,291 A2.5,2.5 0 0,1 191.5,286 Z"
        android:fillColor="#5EEAD4"
        android:fillAlpha="0.4"/>

    <!-- Transcription lines — row 3 -->
    <path
        android:pathData="M53.5,300 L108.5,300 A2.5,2.5 0 0,1 108.5,305 L53.5,305 A2.5,2.5 0 0,1 53.5,300 Z"
        android:fillColor="#5EEAD4"
        android:fillAlpha="0.5"/>
    <path
        android:pathData="M121.5,300 L216.5,300 A2.5,2.5 0 0,1 216.5,305 L121.5,305 A2.5,2.5 0 0,1 121.5,300 Z"
        android:fillColor="#5EEAD4"
        android:fillAlpha="0.3"/>

</vector>
